{
  "manifest_version": 3,
  "name": "Stash",
  "version": "1.0.0",
  "description": "Save your AI chats and the pages you read to a private archive that lives only on your device.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stash",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon.png"
  }
}
